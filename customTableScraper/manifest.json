{
  "manifest_version": 3,
  "name": "Google Admin - Shared Drive Table Exporter",
  "version": "1.0",
  "description": "Extracts Shared Drives data from the Shared Drive table in the Google Admin console.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "icons": {
    "16": "table-icon.png",
    "48": "table-icon.png",
    "128": "table-icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "table-icon.png",
      "48": "table-icon.png",
      "128": "table-icon.png"
    }
  }
}